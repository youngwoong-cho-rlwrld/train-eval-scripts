# SKT (AWS ParallelCluster, us-east-1) cluster config
# Sourced by submit + lib/{train,eval}_body.sh after CLUSTER is set to 'skt'.
export CLUSTER=skt
export PARTITION=l40s-gpu
export REPO_ROOT=/fsx/rlwrld/youngwoong_cho/train-eval-scripts
export GROOT_DIR=/fsx/rlwrld/youngwoong_cho/workspace/gr00t
export GROOT_N16_DIR=/fsx/rlwrld/youngwoong_cho/workspace/gr00t-n16
export ISAAC_DIR=/fsx/rlwrld/youngwoong_cho/workspace/rlwrld_isaac
export DATA_DIR=/fsx/rlwrld/youngwoong_cho/datasets/v4
export LOG_DIR=/fsx/rlwrld/youngwoong_cho/logs
